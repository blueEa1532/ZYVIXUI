local ui = loadstring(game:HttpGet("https://raw.githubusercontent.com/blueEa1532/ZYVIXUI/refs/heads/main/ZYVIX/ZYVIXUI.lua"))()

local h4ck3r = ui:CreateWindow()

local tablist = h4ck3r:Tablist()

local tab2 = tablist:CreateTab("hei")

local sec = tab2:Section(tab2)
sec:Button({
	Label = "tesxr",
	Callback = function()
		print("Weopfkweopfkweopwf")
	end,
})

sec:Checkbox({
	Label = "hey",
	Value = true,
	Callback = function(self, value)
		print(value)
	end,
})

sec:Divider()

sec:Dropdown({
	Label = "Dropdown",
	Items = {
		"hello",
		"option 2"
	},
	selected = 1,
	Callback = function(self, value)
		print("selected:", value)
	end,
})

sec:Label({Text = "hello"})

local fuck_you = 24

sec:InputBox({
	Label = "Jump",
	placeholder_text = "number",
	value = "24",
	Callback = function(self, value)
		fuck_you = value
		print(fuck_you)
	end,
})

sec:Slider({
	Label = "speed",
	Minimum = 0,
	Maximum = 100,
	Value = 25,
	Callback = function(self, value)
		print("yay", value)
	end,
})

sec:Keybind({
	Label = "Fly Keybind",
	DefaultValue = Enum.KeyCode.F,
	Callback = function(self, value)
		print("just look around")
	end,
})
